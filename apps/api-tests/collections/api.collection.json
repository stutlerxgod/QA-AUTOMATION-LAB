        {
          "name": "GET Verify user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Response code in body is 200\", function () {\r",
                  "    pm.expect(pm.response.json().responseCode).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User has required fields\", function () {\r",
                  "    const user = pm.response.json().user;\r",
                  "    pm.expect(user).to.have.property(\"id\");\r",
                  "    pm.expect(user.name).to.eql(pm.variables.get(\"name\"));\r",
                  "    pm.expect(user.email).to.eql(pm.variables.get(\"email\"));\r",
                  "    pm.expect(user.title).to.eql(pm.variables.get(\"title\"));\r",
                  "    pm.expect(user.birth_day).to.eql(pm.variables.get(\"birth_date\"));\r",
                  "    pm.expect(user.birth_month).to.eql(pm.variables.get(\"birth_month\"));\r",
                  "    pm.expect(user.birth_year).to.eql(pm.variables.get(\"birth_year\"));\r",
                  "    pm.expect(user.first_name).to.eql(pm.variables.get(\"first_name\"));\r",
                  "    pm.expect(user.last_name).to.eql(pm.variables.get(\"last_name\"));\r",
                  "    pm.expect(user.company).to.eql(pm.variables.get(\"company\"));\r",
                  "    pm.expect(user.address1).to.eql(pm.variables.get(\"address1\"));\r",
                  "    pm.expect(user.address2).to.eql(pm.variables.get(\"address2\"));\r",
                  "    pm.expect(user.country).to.eql(pm.variables.get(\"country\"));\r",
                  "    pm.expect(user.state).to.eql(pm.variables.get(\"state\"));\r",
                  "    pm.expect(user.city).to.eql(pm.variables.get(\"city\"));\r",
                  "    pm.expect(user.zipcode).to.eql(pm.variables.get(\"zipcode\"));\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
