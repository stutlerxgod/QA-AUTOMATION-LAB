{
  "name": "qa-automation-lab",
  "version": "1.0.0",
  "description": "QA automation lab with Playwright UI tests and Newman API tests for automationexercise.com",
  "main": "index.js",
  "scripts": {
    "test:ui": "cucumber-js --config apps/ui-tests/cucumber.js",
    "test:ui-headed": "cucumber-js --config apps/ui-tests/cucumber.js --world-parameters '{\"headless\":false,\"slowMo\":500}' --tags @only",
    "test:ui-tracing": "npx playwright show-trace",
    "setup:cookie": "ts-node apps/ui-tests/utils/cookieSetup.ts",
    "test:api": "newman run apps/api-tests/collections/api.collection.json --environment apps/api-tests/environments/prod.env.json",
    "test:api:report": "newman run apps/api-tests/collections/api.collection.json --environment apps/api-tests/environments/prod.env.json --reporters cli,htmlextra --reporter-htmlextra-export apps/api-tests/reports/report.html",
    "docker:build": "docker compose build",
    "docker:test:ui": "docker compose run --rm ui-tests",
    "docker:test:api": "docker compose run --rm api-tests"
  },
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
